{
  "name": "music-meta",
  "version": "0.1.0",
  "description": "CLI tool to bulk-edit MP3/FLAC metadata tags",
  "main": "dist/index.js",
  "bin": {
    "music-meta": "./dist/index.js"
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "keywords": ["music", "mp3", "flac", "metadata", "id3", "cli"],
  "author": "whatjackhasmade",
  "license": "ISC",
  "scripts": {
    "bulk": "tsx --tsconfig tsconfig.json src/index.ts bulk",
    "scan": "tsx --tsconfig tsconfig.json src/index.ts scan",
    "dev":  "tsx --tsconfig tsconfig.json src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --minify --alias:@=./src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postbuild": "chmod +x dist/index.js"
  },
  "devDependencies": {
    "@types/inquirer": "9.0.9",
    "@types/node": "25.5.0",
    "esbuild": "^0.27.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@inquirer/prompts": "8.3.2",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "inquirer": "13.3.2",
    "music-metadata": "11.12.3",
    "node-id3": "0.2.9",
    "node-taglib-sharp": "6.0.1",
    "ora": "9.3.0"
  }
}
