{
  "type": "module",
  "name": "@wjhm/music-meta",
  "version": "0.2.3",
  "description": "CLI tool to bulk-edit MP3/FLAC metadata tags",
  "main": "dist/index.cjs",
  "bin": {
    "music-meta": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "music",
    "mp3",
    "flac",
    "metadata",
    "id3",
    "cli"
  ],
  "author": "whatjackhasmade",
  "license": "ISC",
  "scripts": {
    "bulk": "tsx --tsconfig tsconfig.json src/index.ts bulk",
    "scan": "tsx --tsconfig tsconfig.json src/index.ts scan",
    "dev": "tsx --tsconfig tsconfig.json src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsx build.ts",
    "prepublishOnly": "npm run build",
    "postbuild": "chmod +x dist/index.cjs"
  },
  "devDependencies": {
    "@types/inquirer": "9.0.9",
    "@types/node": "25.5.0",
    "esbuild": "^0.27.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@inquirer/prompts": "8.3.2",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "inquirer": "13.3.2",
    "music-metadata": "11.12.3",
    "node-id3": "0.2.9",
    "node-taglib-sharp": "6.0.1",
    "ora": "9.3.0"
  }
}
